# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://app.chocka.co.uk/api/auth/callback/google

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_MONTHLY_PRICE_ID=your_monthly_price_id
STRIPE_YEARLY_PRICE_ID=your_yearly_price_id

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Resend (email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Chocka <hello@chocka.co.uk>

# Anthropic (AI post/reply generation)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Cron secret
CRON_SECRET=your_cron_secret

# App
NEXT_PUBLIC_APP_URL=https://app.chocka.co.uk
